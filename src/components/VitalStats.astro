---
interface Props {
  best_for: string;
  climate: string;
  hub: string;
  currency: string;
  ship_class: string;
}
const { best_for, climate, hub, currency, ship_class } = Astro.props;
---

<aside class="vital-stats">
  <h2 class="vital-stats__title">Vital Statistics</h2>
  <ul class="vital-stats__list">
    <li><span class="vs-label">Best For</span><span class="vs-value">{best_for}</span></li>
    <li><span class="vs-label">Climate</span><span class="vs-value">{climate}</span></li>
    <li><span class="vs-label">Hub</span><span class="vs-value">{hub}</span></li>
    <li><span class="vs-label">Currency</span><span class="vs-value">{currency}</span></li>
    <li><span class="vs-label">Ship Class</span><span class="vs-value">{ship_class}</span></li>
  </ul>
</aside>

<style>
  .vital-stats {
    background: var(--color-surface-paper);
    border-left: 4px solid var(--color-primary-600);
    padding: 1.25rem 1.5rem;
    position: sticky;
    top: 4rem;
  }

  .vital-stats__title {
    font-family: var(--font-display);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary-600);
    margin: 0 0 0.875rem;
  }

  .vital-stats__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .vital-stats__list li {
    display: flex;
    flex-direction: column;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
  }

  .vital-stats__list li:last-child {
    border-bottom: none;
  }

  .vs-label {
    font-family: var(--font-body);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-neutral-500);
    margin-bottom: 0.125rem;
  }

  .vs-value {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-neutral-800);
    line-height: 1.4;
  }
</style>
