---
interface Crumb {
  label: string;
  href: string | null;
}

interface Props {
  crumbs: Crumb[];
  title: string;
}

const { crumbs, title } = Astro.props;
---

<nav class="breadcrumb" aria-label="Location breadcrumb">
  {crumbs.map((crumb) => (
    <>
      {crumb.href
        ? <a href={crumb.href} class="breadcrumb__item breadcrumb__item--link">{crumb.label}</a>
        : <span class="breadcrumb__item">{crumb.label}</span>
      }
      <span class="breadcrumb__sep" aria-hidden="true">›</span>
    </>
  ))}
  <span class="breadcrumb__item breadcrumb__item--current">{title}</span>
</nav>

<style>
  .breadcrumb {
    font-family: var(--font-display);
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.65);
    display: flex;
    align-items: center;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .breadcrumb__sep {
    opacity: 0.45;
  }

  .breadcrumb__item--link {
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
  }

  .breadcrumb__item--link:hover {
    color: rgba(255, 255, 255, 0.95);
    text-decoration: underline;
  }

  .breadcrumb__item--current {
    color: rgba(255, 255, 255, 0.95);
    font-weight: 600;
  }
</style>
