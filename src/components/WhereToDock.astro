---
interface Props {
  title: string
  category: 'landing-zone' | 'habitation' | 'rest-stop'
  image: string
  imageAlt: string
}

const { title, category, image, imageAlt } = Astro.props

const categoryLabels = {
  'landing-zone': '🛬 Landing Zone',
  'habitation': '🏠 Habitation',
  'rest-stop': '☕ Rest Stop'
}
---

<section class="docks-entry">
  <div class="docks-category-label">{categoryLabels[category]}</div>
  <h3 class="docks-title">{title}</h3>
  <div class="docks-image">
    <img src={image} alt={imageAlt} loading="lazy" />
  </div>
  <div class="docks-description">
    <slot />
  </div>
</section>

<style>
  .docks-entry {
    margin: 2rem 0;
    border-bottom: 1px solid #e5e7eb;
    padding-bottom: 2rem;
  }
  .docks-entry:last-child {
    border-bottom: none;
  }

  .docks-category-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #6b7280;
    margin-bottom: 0.75rem;
  }

  .docks-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: #292424;
    margin-bottom: 1rem;
    font-family: Georgia, serif;
  }

  .docks-image {
    margin-bottom: 1rem;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .docks-image img {
    width: 100%;
    height: 12rem;
    object-fit: cover;
  }

  .docks-description {
    color: #44403c;
    line-height: 1.6;
  }
</style>