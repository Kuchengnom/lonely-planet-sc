---
interface Props {
  author: string;
}
const { author } = Astro.props;
---

<aside class="explorer-view">
  <div class="explorer-view__label">The Explorer's View</div>
  <blockquote class="explorer-view__quote">
    <slot />
  </blockquote>
  <cite class="explorer-view__author">— {author}</cite>
</aside>

<style>
  .explorer-view {
    background: #EEF2FF;
    border-left: 4px solid #7c3aed;
    padding: 1.25rem 1.5rem;
    margin: 2rem 0;
  }

  .explorer-view__label {
    font-family: var(--font-display);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #7c3aed;
    margin-bottom: 0.75rem;
  }

  .explorer-view__quote {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-style: italic;
    line-height: var(--line-height-relaxed);
    color: var(--color-neutral-800);
    margin: 0 0 0.75rem;
  }

  .explorer-view__author {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-neutral-600);
    font-style: normal;
  }
</style>
