---
interface Props {
  number: number
}

const { number } = Astro.props
---

<section class="eating-section">
  <div class="eating-number">{number}</div>
  <div class="eating-content">
    <slot />
  </div>
</section>

<style>
  .eating-section {
    margin: 2rem 0;
    border-left: 4px solid #d1d5db;
    padding: 1rem;
    background-color: #fafaf9;
  }

  .eating-number {
    font-size: 3.75rem;
    font-weight: 700;
    color: #e5e7eb;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .eating-content {
    color: #44403c;
  }
</style>