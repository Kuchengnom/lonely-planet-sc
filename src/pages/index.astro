---
import '../styles/global.css';

const base = import.meta.env.BASE_URL + (import.meta.env.BASE_URL.endsWith('/') ? '' : '/');

interface Edition {
  name: string;
  subtitle: string;
  tagline: string;
  status: 'available' | 'coming-soon';
  href: string;
  theme: 'stanton' | 'pyro' | 'terra' | 'nyx';
}

const EDITIONS: Edition[] = [
  {
    name: 'Stanton',
    subtitle: 'The Corporate Core',
    tagline: 'Four planets. Four corporations. One system where power is the currency.',
    status: 'available',
    href: `${base}stanton/`,
    theme: 'stanton',
  },
  {
    name: 'Pyro',
    subtitle: 'The Unstable Frontier',
    tagline: 'Six planets of volatile hostility and a near-total absence of law.',
    status: 'available',
    href: `${base}pyro/`,
    theme: 'pyro',
  },
  {
    name: 'Terra',
    subtitle: 'The Capital World',
    tagline: 'The cultural and political heart of the UEE — cosmopolitan, ambitious, complicated.',
    status: 'coming-soon',
    href: '#',
    theme: 'terra',
  },
  {
    name: 'Nyx',
    subtitle: 'The Lawless Fringe',
    tagline: 'Home of Delamar and Levski. The rebel answer to Pyro\'s chaos.',
    status: 'coming-soon',
    href: '#',
    theme: 'nyx',
  },
];

interface Destination {
  name: string;
  label: string;
  href: string;
  system: 'stanton' | 'pyro';
}

const DESTINATIONS: { system: string; color: string; items: Destination[] }[] = [
  {
    system: 'Stanton',
    color: 'var(--color-primary-600)',
    items: [
      { name: 'Hurston',  label: 'Stanton I',   href: `${base}stanton/hurston/`,   system: 'stanton' },
      { name: 'Crusader', label: 'Stanton II',  href: `${base}stanton/crusader/`,  system: 'stanton' },
      { name: 'ArcCorp',  label: 'Stanton III', href: `${base}stanton/arccorp/`,   system: 'stanton' },
      { name: 'microTech',label: 'Stanton IV',  href: `${base}stanton/microtech/`, system: 'stanton' },
    ],
  },
  {
    system: 'Pyro',
    color: '#c2410c',
    items: [
      { name: 'Pyro I–VI',      label: 'All Planets',     href: `${base}pyro/`,                        system: 'pyro' },
      { name: 'Ruin Station',   label: 'Lagrange Point 1',href: `${base}pyro/stations/ruin-station/`,  system: 'pyro' },
      { name: 'Pyro Belt',      label: 'Asteroid Field',  href: `${base}pyro/stations/pyro-belt/`,     system: 'pyro' },
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lonely Planet: Star Citizen</title>
    <meta name="description" content="Unofficial travel guides to the Star Citizen universe. Curated attractions, hidden gems, and essential travel tips." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Narrow:wght@400;700&family=Merriweather:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono&display=swap" rel="stylesheet" />
  </head>

  <body>
    {/* ── Hero ──────────────────────────────── */}
    <header class="hero", style={`background: linear-gradient(180deg, rgba(9,20,45,.78), rgba(9,20,45,.48)), url(${base}images/microtech/panoramic-lake.jpeg) center / cover no-repeat`}>
      <div class="hero__pattern"></div>
      <div class="hero__inner">
        <div class="hero__pin" aria-hidden="true">&#9733;</div>
        <h1 class="hero__title">Lonely Planet</h1>
        <p class="hero__subtitle">Star Citizen</p>
        <p class="hero__lede">
          Unofficial travel guides to the 'Verse. Curated attractions, hidden gems,
          and essential travel tips for the systems you fly through.
        </p>
        <div class="hero__scroll" aria-hidden="true">
          <span>Scroll</span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
    </header>

    <main>
      {/* ── System Editions ─────────────────── */}
      <section class="editions" aria-labelledby="editions-heading">
        <div class="container">
          <h2 id="editions-heading" class="section-heading">System Editions</h2>

          <div class="editions-grid">
            {EDITIONS.map((ed) => (
              <article class={`edition-card edition-card--${ed.theme} ${ed.status === 'coming-soon' ? 'edition-card--soon' : ''}`}>
                <div class="edition-card__thumb">
                  <div class="edition-card__planet" aria-hidden="true"></div>
                  <div class="edition-card__overlay"></div>
                  <span class={`edition-card__status-badge ${ed.status === 'available' ? 'edition-card__status-badge--live' : ''}`}>
                    {ed.status === 'available' ? 'Available Now' : 'Coming Soon'}
                  </span>
                  <span class="edition-card__lp-badge">LP</span>
                  <div class="edition-card__thumb-text">
                    <span class="edition-card__eyebrow">Star Citizen</span>
                    <h3 class="edition-card__name">{ed.name}</h3>
                  </div>
                </div>
                <div class="edition-card__body">
                  <p class="edition-card__subtitle">{ed.subtitle}</p>
                  <p class="edition-card__tagline">{ed.tagline}</p>
                  {ed.status === 'available' ? (
                    <a href={ed.href} class="edition-card__cta">Explore →</a>
                  ) : (
                    <span class="edition-card__cta edition-card__cta--disabled">Coming soon</span>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      {/* ── Destinations Quick-Nav ──────────── */}
      <section class="quick-nav" aria-labelledby="destinations-heading">
        <div class="container">
          <h2 id="destinations-heading" class="section-heading">Destinations</h2>

          <div class="dest-grid">
            {DESTINATIONS.map((group) => (
              <div class="dest-group">
                <p class="dest-group__label" style={`color: ${group.color};`}>{group.system}</p>
                <ul class="dest-list">
                  {group.items.map((dest) => (
                    <li class="dest-item">
                      <a href={dest.href} class={`dest-link dest-link--${dest.system}`}>
                        <span class="dest-link__name">{dest.name}</span>
                        <span class="dest-link__label">{dest.label}</span>
                        <span class={`dest-link__tag dest-link__tag--${dest.system}`}>Live</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* ── About / Manifesto ───────────────── */}
      <section class="about" aria-labelledby="about-heading">
        <div class="container about-grid">
          <div class="about-image">
            <img src={`${base}images/microtech/flying-over-mountains.jpeg`} alt="Small exploration ship flying over microTech's snowy mountain ranges" loading="lazy" />
          </div>
          <div class="about-text">
            <h2 id="about-heading" class="about-heading">For the Explorer</h2>
            <p class="about-lede">
              The 'Verse is vast, cold, and spectacular. These are the places that make the journey worth it.
            </p>
            <p>
              This is an unofficial fan guide inspired by the spirit of classic travel writing.
              We focus on the atmospheric and the hidden — the rivers that shouldn't flow,
              the caves that glow, and the silence between ice storms.
            </p>
            <p>All content is community-driven. Found a new spot? Help us map the 'Verse.</p>
          </div>
        </div>
      </section>
    </main>

    {/* ── Footer ──────────────────────────── */}
    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <p class="footer-title">Editions</p>
          <ul class="footer-links">
            <li><a href={`${base}stanton/`}>Stanton</a></li>
            <li><a href={`${base}pyro/`}>Pyro</a></li>
            <li><a href="#" style="opacity:0.45;pointer-events:none;">Terra</a></li>
            <li><a href="#" style="opacity:0.45;pointer-events:none;">Nyx</a></li>
          </ul>
        </div>
        <div>
          <p class="footer-title">Community</p>
          <ul class="footer-links">
            <li><a href="https://robertsspaceindustries.com/" target="_blank" rel="noopener">Star Citizen</a></li>
            <li><a href="https://starcitizen.tools/" target="_blank" rel="noopener">Star Citizen Wiki</a></li>
          </ul>
        </div>
        <div class="footer-col-wide">
          <p class="footer-small">Fan-made reference guide. Star Citizen and related marks belong to Cloud Imperium Rights LLC and Cloud Imperium Rights Ltd.</p>
        </div>
      </div>
    </footer>

  </body>
</html>

<style>
  /* ── Base / Typography ─────────────────── */
  body {
    background: #f5f0ea;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .container {
    max-width: 1024px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-neutral-500);
    margin: 0 0 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-neutral-200);
  }

  /* ── Hero ──────────────────────────────── */
  .hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
    background:
      linear-gradient(180deg, rgba(9,20,45,.78), rgba(9,20,45,.48)) center / cover no-repeat;
    color: #fff;
  }

  .hero__pattern {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,.04) 2px,
      rgba(0,0,0,.04) 4px
    );
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    max-width: 700px;
  }

  .hero__pin {
    font-size: 2.5rem;
    line-height: 1;
    opacity: .6;
    margin-bottom: .5rem;
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    line-height: .9;
    margin: 0;
  }

  .hero__subtitle {
    font-family: var(--font-body);
    font-size: clamp(1rem, 3vw, 1.5rem);
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,.65);
    margin: .625rem 0 1.5rem;
  }

  .hero__lede {
    font-family: var(--font-body);
    font-size: clamp(0.9375rem, 2vw, 1.125rem);
    line-height: var(--line-height-relaxed);
    color: rgba(255,255,255,.75);
    max-width: 540px;
    margin: 0 auto;
  }

  .hero__scroll {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .375rem;
    margin-top: 2.5rem;
    font-family: var(--font-display);
    font-size: .625rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: rgba(255,255,255,.4);
  }

  .hero__scroll svg {
    width: 20px;
    height: 20px;
    animation: bounce 2s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ── Editions Section ──────────────────── */
  .editions { padding: 3.5rem 0 4rem; }

  .editions-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .edition-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-md, 0.5rem);
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,.08);
    transition: transform .25s ease, box-shadow .25s ease;
    background: #fff;
  }

  .edition-card:hover { transform: translateY(-5px); box-shadow: 0 12px 30px rgba(0,0,0,.13); }
  .edition-card--soon { opacity: .85; }
  .edition-card--soon:hover { transform: none; box-shadow: 0 2px 8px rgba(0,0,0,.08); }

  /* Thumb */
  .edition-card__thumb {
    position: relative;
    height: 220px;
    overflow: hidden;
  }

  /* Theme backgrounds */
  .edition-card--stanton .edition-card__thumb { background: linear-gradient(160deg, #1e3a5c 0%, #0d1f35 55%, #040c18 100%); }
  .edition-card--pyro    .edition-card__thumb { background: linear-gradient(160deg, #3a1a0a 0%, #1e0d04 55%, #0a0400 100%); }
  .edition-card--terra   .edition-card__thumb { background: linear-gradient(160deg, #0a2a1a 0%, #051510 55%, #020a06 100%); }
  .edition-card--nyx     .edition-card__thumb { background: linear-gradient(160deg, #1a1a2e 0%, #0d0d1e 55%, #050510 100%); }

  /* CSS planets */
  .edition-card__planet {
    position: absolute;
    bottom: -20px; right: -20px;
    width: 130px; height: 130px;
    border-radius: 50%;
  }
  .edition-card--stanton .edition-card__planet { background: radial-gradient(circle at 30% 30%, #4a8be5, #1a3a6c, #040c18); box-shadow: inset -14px -10px 35px rgba(0,0,0,.8), 0 0 50px rgba(58,123,213,.25); }
  .edition-card--pyro    .edition-card__planet { background: radial-gradient(circle at 30% 30%, #e55a1a, #8b2500, #1a0500); box-shadow: inset -14px -10px 35px rgba(0,0,0,.7), 0 0 60px rgba(229,90,26,.35); }
  .edition-card--terra   .edition-card__planet { background: radial-gradient(circle at 30% 30%, #2aaa6a, #0d5530, #020f08); box-shadow: inset -14px -10px 35px rgba(0,0,0,.7), 0 0 50px rgba(42,170,106,.2); }
  .edition-card--nyx     .edition-card__planet { background: radial-gradient(circle at 30% 30%, #7a4aaa, #3a1a5c, #0a0518); box-shadow: inset -14px -10px 35px rgba(0,0,0,.8), 0 0 50px rgba(122,74,170,.2); }

  .edition-card__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,.12) 0%, transparent 40%, rgba(0,0,0,.65) 85%);
  }

  /* Badges */
  .edition-card__lp-badge {
    position: absolute; top: .625rem; right: .625rem;
    background: #f5c518;
    font-family: var(--font-display);
    font-size: .5625rem; font-weight: 900;
    letter-spacing: .12em; text-transform: uppercase;
    color: #1a1a1a; padding: .1875rem .4375rem;
    line-height: 1.4;
  }
  .edition-card__status-badge {
    position: absolute; top: .625rem; left: .625rem;
    font-family: var(--font-display);
    font-size: .5rem; font-weight: 800;
    letter-spacing: .08em; text-transform: uppercase;
    color: #fff; padding: .1875rem .5rem;
    border-radius: 2px;
    background: rgba(255,255,255,.18);
    backdrop-filter: blur(4px);
  }
  .edition-card__status-badge--live { background: #059669; backdrop-filter: none; }

  /* Title block inside thumb */
  .edition-card__thumb-text {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: .875rem .75rem .75rem;
  }
  .edition-card__eyebrow {
    display: block;
    font-family: var(--font-display);
    font-size: .5rem; font-weight: 700;
    letter-spacing: .15em; text-transform: uppercase;
    color: rgba(255,255,255,.5); margin-bottom: .1875rem;
  }
  .edition-card__name {
    font-family: var(--font-display);
    font-size: 1.75rem; font-weight: 900;
    line-height: .9; letter-spacing: -.02em;
    text-transform: uppercase; color: #fff; margin: 0;
  }

  /* Card body */
  .edition-card__body {
    padding: .75rem 1rem 1rem;
    display: flex; flex-direction: column; flex: 1;
    background: #fff;
  }
  .edition-card__subtitle {
    font-family: var(--font-body);
    font-size: .75rem; font-style: italic;
    color: var(--color-neutral-500); margin: 0 0 .375rem;
  }
  .edition-card__tagline {
    font-family: var(--font-body);
    font-size: .75rem; color: var(--color-neutral-600);
    line-height: 1.4; flex: 1; margin: 0 0 .75rem;
  }
  .edition-card__cta {
    display: inline-block; align-self: flex-start;
    font-family: var(--font-display);
    font-size: .6875rem; font-weight: 800;
    letter-spacing: .06em; text-transform: uppercase;
    color: var(--color-primary-700);
    text-decoration: none;
    border-bottom: 2px solid currentColor; padding-bottom: 1px;
    transition: opacity .2s;
  }
  .edition-card__cta:hover { opacity: .7; }
  .edition-card__cta--disabled { pointer-events: none; color: var(--color-neutral-400); border-color: var(--color-neutral-300); }

  /* ── Destinations Nav ──────────────────── */
  .quick-nav { padding: 0 0 4rem; }

  .dest-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .dest-group__label {
    font-family: var(--font-display);
    font-size: .625rem; font-weight: 800;
    letter-spacing: .12em; text-transform: uppercase;
    margin: 0 0 .5rem;
  }

  .dest-list { list-style: none; margin: 0; padding: 0; }

  .dest-item { border-top: 1px solid var(--color-neutral-200); }
  .dest-item:last-child { border-bottom: 1px solid var(--color-neutral-200); }

  .dest-link {
    display: flex; align-items: center; gap: 1rem;
    padding: .75rem 0; text-decoration: none; color: inherit;
    transition: background .15s;
  }
  .dest-link:hover { background: rgba(0,0,0,.02); }

  .dest-link__name {
    font-family: var(--font-display);
    font-size: 1rem; font-weight: 700;
    color: var(--color-neutral-900); min-width: 130px;
  }
  .dest-link__label {
    font-family: var(--font-body);
    font-size: .8125rem; color: var(--color-neutral-500); flex: 1;
  }
  .dest-link__tag {
    font-family: var(--font-display);
    font-size: .5625rem; font-weight: 700;
    letter-spacing: .06em; text-transform: uppercase;
    padding: .125rem .4375rem; border-radius: var(--radius-sm, .25rem);
  }
  .dest-link__tag--stanton { background: #eff6ff; color: var(--color-primary-700); }
  .dest-link__tag--pyro    { background: #fff7ed; color: #c2410c; }

  /* ── About / Manifesto ─────────────────── */
  .about {
    background: #fff;
    padding: 4rem 0;
    border-top: 1px solid var(--color-neutral-200);
    border-bottom: 1px solid var(--color-neutral-200);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .about-image {
    border-radius: var(--radius-md, .5rem);
    overflow: hidden;
  }

  .about-image img {
    width: 100%;
    height: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
  }

  .about-heading {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-neutral-900);
    margin: 0 0 .75rem;
  }

  .about-lede {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    font-style: italic;
    color: var(--color-neutral-700);
    line-height: var(--line-height-relaxed);
    margin: 0 0 1.25rem;
  }

  .about-text p {
    font-family: var(--font-body);
    font-size: .9375rem;
    line-height: var(--line-height-relaxed);
    color: var(--color-neutral-700);
    margin: 0 0 .75rem;
  }

  .about-text p:last-child {
    margin-bottom: 0;
  }

  /* ── Footer ────────────────────────────── */
  .site-footer {
    background: var(--color-neutral-900);
    color: #a0aec0;
    padding: 2.5rem 0 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 2fr;
    gap: 2rem;
    align-items: start;
  }

  .footer-title {
    font-family: var(--font-display);
    font-size: .625rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: rgba(255,255,255,.5);
    margin: 0 0 .75rem;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-links li {
    margin-bottom: .375rem;
  }

  .footer-links a {
    color: #a0aec0;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: .8125rem;
    transition: color .2s ease;
  }

  .footer-links a:hover {
    color: #fff;
  }

  .footer-col-wide {
    align-self: end;
  }

  .footer-small {
    font-family: var(--font-body);
    font-size: .6875rem;
    color: #718096;
    line-height: 1.6;
    margin: 0;
  }

  /* ── Responsive ────────────────────────── */
  @media (max-width: 900px) {
    .editions-grid { grid-template-columns: repeat(2, 1fr); }
    .dest-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .editions-grid { grid-template-columns: repeat(2, 1fr); }

    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-image {
      order: -1;
    }

    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-col-wide {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .planet-link {
      flex-wrap: wrap;
      gap: .25rem .75rem;
    }

    .planet-link__label {
      order: 3;
      width: 100%;
    }
  }
</style>