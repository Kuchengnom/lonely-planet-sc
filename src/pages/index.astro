---
import '../styles/global.css';

const base = import.meta.env.BASE_URL + (import.meta.env.BASE_URL.endsWith('/') ? '' : '/');

interface Edition {
  name: string;
  subtitle: string;
  tagline: string;
  status: 'available' | 'coming-soon';
  href: string;
  theme: 'stanton' | 'pyro' | 'terra' | 'nyx';
  coverBg: string;
  coverImg?: string;
  coverImgFilter?: string;
  coverLabel: string;
}

const EDITIONS: Edition[] = [
  {
    name: 'Stanton',
    subtitle: 'The Corporate Core',
    tagline: 'Four planets. Four corporations. One system where power is the only currency.',
    status: 'available',
    href: `${base}stanton/`,
    theme: 'stanton',
    coverBg: '#0d1f3a',
    coverImg: `${base}images/microtech/panoramic-lake.jpeg`,
    coverLabel: 'UEE Territory',
  },
  {
    name: 'Pyro',
    subtitle: 'The Unstable Frontier',
    tagline: 'Six planets of volatile hostility and a near-total absence of law.',
    status: 'available',
    href: `${base}pyro/`,
    theme: 'pyro',
    coverBg: '#2e1507',
    coverImg: `${base}images/microtech/canyon-forest.jpeg`,
    coverImgFilter: 'hue-rotate(180deg) saturate(1.3) brightness(0.6)',
    coverLabel: 'Contested Space',
  },
  {
    name: 'Terra',
    subtitle: 'The Capital World',
    tagline: 'Cultural and political heart of the UEE — cosmopolitan, ambitious, complicated.',
    status: 'coming-soon',
    href: '#',
    theme: 'terra',
    coverBg: '#0a2a1a',
    coverLabel: 'UEE Capital',
  },
  {
    name: 'Nyx',
    subtitle: 'The Lawless Fringe',
    tagline: 'Home of Delamar and Levski. The rebel answer to Pyro\'s chaos.',
    status: 'coming-soon',
    href: '#',
    theme: 'nyx',
    coverBg: '#0f0f1e',
    coverLabel: 'Contested Space',
  },
];

const POIS = [
  { num: '01', name: 'The First River',        tag: 'Natural Wonder', desc: 'Open water on a permafrost world. The anomaly that has no satisfying explanation.',            planet: 'microTech · Stanton', href: `${base}stanton/microtech/` },
  { num: '02', name: 'Bioluminescent Caves',   tag: 'Hidden Find',    desc: 'Blue-cyan ceilings that look like an inverted starfield. Not on any official map.',           planet: 'microTech · Stanton', href: `${base}stanton/microtech/` },
  { num: '03', name: 'New Babbage Commons',    tag: 'Settlement',     desc: 'Corporate grandeur bordering on absurdist. The warmest welcome on the coldest planet.',       planet: 'microTech · Stanton', href: `${base}stanton/microtech/` },
  { num: '04', name: 'The Canyon River',       tag: 'Natural Wonder', desc: 'Canyon walls and a colour palette that screenshots struggle to convey. Fly it slowly.',        planet: 'microTech · Stanton', href: `${base}stanton/microtech/northern-wastes/canyon-river` },
  { num: '05', name: 'Orison',                 tag: 'Settlement',     desc: 'A city built on platforms in the clouds of a gas giant. Nowhere else in the \'Verse like it.', planet: 'Crusader · Stanton',  href: `${base}stanton/crusader/` },
  { num: '06', name: 'Frozen Lakes',           tag: 'Natural Wonder', desc: 'Arches and columns of compressed blue-white ice. Walk them carefully — the footing is uneven.', planet: 'microTech · Stanton', href: `${base}stanton/microtech/` },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lonely Planet: Star Citizen</title>
    <meta name="description" content="Unofficial travel guides to the Star Citizen universe. Curated attractions, hidden gems, and essential travel tips." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Narrow:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Merriweather:ital,wght@0,300;0,400;0,700;1,300;1,400&display=swap" rel="stylesheet" />
  </head>

  <body>

    <!-- Top announcement strip -->
    <div class="top-strip">
      All Star Citizen editions are <strong>completely free</strong> — community-written, forever open access
    </div>

    <!-- Sticky header -->
    <header class="site-header">
      <div class="header-inner">
        <nav class="nav-left">
          <a href="#editions">Editions</a>
          <a href="#attractions">Attractions</a>
          <a href="#about">About</a>
        </nav>

        <a href={base} class="logo">
          <span class="logo-lp">Lonely <span>Planet</span></span>
          <span class="logo-sub">Star Citizen Edition</span>
        </a>

        <nav class="nav-right">
          <a href="https://github.com/Kuchengnom/lonely-planet-sc" target="_blank" rel="noopener">Contribute</a>
          <a href="https://robertsspaceindustries.com/" target="_blank" rel="noopener">Community</a>
        </nav>
      </div>
    </header>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-bg" style={`background-image: url(${base}images/microtech/flying-over-mountains.jpeg)`}></div>
      <div class="hero-inner">
        <p class="hero-eyebrow">New Edition Available</p>
        <h1>The&nbsp;'Verse<br>awaits.<br><em>No ticket needed.</em></h1>
        <p class="hero-lead">Unofficial travel guides to Star Citizen — written by explorers, for explorers. Curated attractions, navigation notes, and hidden gems. Every edition, completely free.</p>
        <div class="hero-ctas">
          <a href={`${base}stanton/microtech/`} class="btn-primary">Explore microTech →</a>
          <a href="#editions" class="btn-ghost">Browse Editions</a>
        </div>
      </div>
      <div class="hero-book" aria-hidden="true">
        <div class="book-cover-mock" style="--cover-bg:#0d1f3a;">
          <div class="cover-img-area">
            <img src={`${base}images/microtech/panoramic-lake.jpeg`} alt="" />
          </div>
          <div class="cover-orange-bar"></div>
          <div class="cover-lp-label">Lonely Planet</div>
          <div class="cover-title-area">
            <div class="cover-planet-name">micro<br>Tech</div>
            <div class="cover-system">Stanton Edition</div>
          </div>
        </div>
      </div>
    </section>

    <main>

      <!-- Editions -->
      <section class="editions-section" id="editions">
        <div class="section-header">
          <h2>System Editions</h2>
        </div>
        <div class="editions-grid">
          {EDITIONS.map((ed) => (
            <article class={`book-card ${ed.status === 'coming-soon' ? 'book-card--soon' : ''}`}>
              <a href={ed.href} class="book-cover-wrap" tabindex={ed.status === 'coming-soon' ? -1 : 0}>
                <div class="book-cover-mock" style={`--cover-bg:${ed.coverBg};`}>
                  {ed.coverImg && (
                    <div class="cover-img-area">
                      <img src={ed.coverImg} alt={ed.name} style={ed.coverImgFilter ? `filter:${ed.coverImgFilter}` : ''} />
                    </div>
                  )}
                  <div class="cover-orange-bar" style={ed.status === 'coming-soon' ? 'background:#555;' : ''}></div>
                  <div class="cover-lp-label" style={ed.status === 'coming-soon' ? 'color:rgba(255,255,255,0.4);' : ''}>Lonely Planet</div>
                  <div class="cover-title-area">
                    <div class="cover-planet-name" style={ed.status === 'coming-soon' ? 'color:rgba(255,255,255,0.45);' : ''}>{ed.name}</div>
                    <div class="cover-system">{ed.coverLabel}</div>
                  </div>
                </div>
                <span class={`cover-badge ${ed.status === 'available' ? 'cover-badge--live' : 'cover-badge--soon'}`}>
                  {ed.status === 'available' ? 'Available' : 'Coming Soon'}
                </span>
              </a>
              <div class="book-meta">
                <h3 class="book-title">{ed.name}</h3>
                <p class="book-subtitle">{ed.subtitle}</p>
                <p class="book-desc">{ed.tagline}</p>
                <div class="book-footer">
                  {ed.status === 'available' ? (
                    <a href={ed.href} class="btn-read">Read Now →</a>
                  ) : (
                    <span class="btn-read btn-read--disabled">In development</span>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- Feature band: editor's pick -->
      <section class="feature-band">
        <div class="feature-inner">
          <img
            class="feature-img"
            src={`${base}images/microtech/bioluminescent-cave.jpeg`}
            alt="Bioluminescent caves on microTech"
            loading="lazy"
          />
          <div class="feature-text">
            <p class="feature-eyebrow">Editor's Pick — Stanton IV</p>
            <h2>Seven reasons to land on microTech</h2>
            <p>Rivers that shouldn't exist, forests that refused to freeze, and caves that light up like an inverted starfield. The corporate ice world is the most quietly spectacular place in the Stanton system.</p>
            <div class="feature-stats">
              <div class="stat">
                <div class="stat-num">7</div>
                <div class="stat-label">Attractions</div>
              </div>
              <div class="stat">
                <div class="stat-num">4</div>
                <div class="stat-label">Hidden Finds</div>
              </div>
              <div class="stat">
                <div class="stat-num">1</div>
                <div class="stat-label">City</div>
              </div>
            </div>
            <a href={`${base}stanton/microtech/`} class="btn-primary">Read the microTech Guide →</a>
          </div>
        </div>
      </section>

      <!-- Top attractions -->
      <section class="poi-section" id="attractions">
        <div class="section-header">
          <h2>Top Attractions</h2>
        </div>
        <div class="poi-grid">
          {POIS.map((poi) => (
            <a href={poi.href} class="poi-card">
              <span class="poi-num">{poi.num}</span>
              <h3 class="poi-name">{poi.name}</h3>
              <span class="poi-tag">{poi.tag}</span>
              <p class="poi-desc">{poi.desc}</p>
              <span class="poi-planet">{poi.planet}</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Community manifesto band -->
      <section class="why-band" id="about">
        <h2>The 'Verse belongs to everyone.<br />So do these guides.</h2>
        <p>Lonely Planet: Star Citizen Edition is a fan-made, community-driven project. No subscriptions, no paywalls — every guide is written by explorers and released freely. Found a hidden gem? Help us map the 'Verse.</p>
        <a href="https://github.com/Kuchengnom/lonely-planet-sc" class="btn-white" target="_blank" rel="noopener">Contribute on GitHub →</a>
      </section>

    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <div class="footer-logo">Lonely <span>Planet</span></div>
          <p>Unofficial fan guide to the Star Citizen universe. Written by explorers, for explorers. Star Citizen and related marks belong to Cloud Imperium Rights LLC.</p>
        </div>
        <div class="footer-col">
          <h4>Editions</h4>
          <ul>
            <li><a href={`${base}stanton/`}>Stanton</a></li>
            <li><a href={`${base}stanton/microtech/`}>microTech</a></li>
            <li><a href={`${base}stanton/crusader/`}>Crusader</a></li>
            <li><a href={`${base}stanton/hurston/`}>Hurston</a></li>
            <li><a href={`${base}stanton/arccorp/`}>ArcCorp</a></li>
            <li><a href={`${base}pyro/`}>Pyro</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Community</h4>
          <ul>
            <li><a href="https://robertsspaceindustries.com/" target="_blank" rel="noopener">Star Citizen</a></li>
            <li><a href="https://starcitizen.tools/" target="_blank" rel="noopener">SC Wiki</a></li>
            <li><a href="https://github.com/Kuchengnom/lonely-planet-sc" target="_blank" rel="noopener">GitHub Repo</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Project</h4>
          <ul>
            <li><a href="#about">About</a></li>
            <li><a href="https://github.com/Kuchengnom/lonely-planet-sc" target="_blank" rel="noopener">How to Contribute</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span>Fan-made reference guide. Not affiliated with Cloud Imperium Games.</span>
        <span>Lonely Planet: Star Citizen Edition</span>
      </div>
    </footer>

  </body>
</html>

<style>
  /* ── Tokens ──────────────────────────────────────────── */
  :root {
    --lp-orange:    #e8420a;
    --lp-orange-dk: #c03208;
    --lp-black:     #1a1714;
    --lp-white:     #ffffff;
    --lp-paper:     #f7f4ef;
    --lp-paper-2:   #ede9e1;
    --lp-rule:      #d4cec3;
    --lp-ink:       #231f1b;
    --lp-muted:     #7a7168;

    --f-display: 'Archivo Narrow', sans-serif;
    --f-body:    'Merriweather', serif;

    --max-w:  1280px;
    --gutter: clamp(16px, 4vw, 48px);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: var(--f-body);
    color: var(--lp-ink);
    background: var(--lp-white);
    -webkit-font-smoothing: antialiased;
  }

  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }

  /* ── Top strip ─────────────────────────────────────── */
  .top-strip {
    background: var(--lp-black);
    color: rgba(255,255,255,0.7);
    font-family: var(--f-display);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
    padding: 8px var(--gutter);
  }
  .top-strip strong { color: var(--lp-orange); font-weight: 700; }

  /* ── Sticky header ─────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--lp-white);
    border-bottom: 2px solid var(--lp-black);
  }

  .header-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 64px;
  }

  .nav-left {
    display: flex;
    gap: 24px;
    font-family: var(--f-display);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .nav-left a:hover { color: var(--lp-orange); }

  .logo {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .logo-lp {
    font-family: var(--f-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1;
    text-transform: uppercase;
  }
  .logo-lp span { color: var(--lp-orange); }
  .logo-sub {
    font-family: var(--f-display);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--lp-muted);
    margin-top: 3px;
  }

  .nav-right {
    display: flex;
    gap: 20px;
    justify-content: flex-end;
    align-items: center;
    font-family: var(--f-display);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .nav-right a:hover { color: var(--lp-orange); }

  /* ── Hero ──────────────────────────────────────────── */
  .hero {
    background: var(--lp-black);
    position: relative;
    overflow: hidden;
    min-height: 520px;
    display: flex;
    align-items: stretch;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 35%;
    opacity: 0.35;
    filter: sepia(20%) contrast(1.1);
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, rgba(232,66,10,0.5) 0%, transparent 55%),
      linear-gradient(to right, rgba(26,23,20,0.92) 0%, rgba(26,23,20,0.18) 70%);
  }

  .hero-inner {
    max-width: var(--max-w);
    width: 100%;
    margin: 0 auto;
    padding: 80px var(--gutter) 72px;
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    max-width: 640px;
  }

  .hero-eyebrow {
    font-family: var(--f-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--lp-orange);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 28px;
    height: 2px;
    background: var(--lp-orange);
    flex-shrink: 0;
  }

  .hero h1 {
    font-family: var(--f-display);
    font-size: clamp(40px, 7vw, 84px);
    font-weight: 700;
    line-height: 0.93;
    letter-spacing: -0.02em;
    color: var(--lp-white);
    margin-bottom: 20px;
  }
  .hero h1 em { font-style: normal; color: var(--lp-orange); }

  .hero-lead {
    font-family: var(--f-display);
    font-size: clamp(14px, 1.8vw, 17px);
    color: rgba(255,255,255,0.7);
    max-width: 460px;
    line-height: 1.6;
    margin-bottom: 32px;
  }

  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ── Book cover (hero + cards shared) ─────────────── */
  .hero-book {
    position: absolute;
    right: var(--gutter);
    bottom: 0;
    width: clamp(150px, 17vw, 240px);
    filter: drop-shadow(-12px 12px 40px rgba(0,0,0,0.7));
    animation: float-book 5s ease-in-out infinite;
    z-index: 3;
  }

  @keyframes float-book {
    0%, 100% { transform: rotate(2deg) translateY(0); }
    50%       { transform: rotate(2deg) translateY(-8px); }
  }

  .book-cover-mock {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    background: var(--cover-bg, #1a1714);
    position: relative;
    overflow: hidden;
  }

  .cover-img-area {
    position: absolute;
    inset: 0;
  }
  .cover-img-area img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.62;
  }

  .cover-orange-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 7px;
    background: var(--lp-orange);
    z-index: 3;
  }

  .cover-lp-label {
    position: absolute;
    top: 16px;
    left: 12px;
    font-family: var(--f-display);
    font-size: 11px;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    z-index: 4;
  }

  .cover-title-area {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 16px 12px 12px;
    background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, transparent 100%);
    z-index: 4;
  }
  .cover-planet-name {
    font-family: var(--f-display);
    font-size: clamp(20px, 3.5vw, 28px);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.01em;
    color: var(--lp-white);
  }
  .cover-system {
    font-family: var(--f-display);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin-top: 4px;
  }

  .cover-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    font-family: var(--f-display);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 4px 8px;
    z-index: 5;
  }
  .cover-badge--live { background: #1a6b3a; color: #fff; }
  .cover-badge--soon { background: var(--lp-black); color: rgba(255,255,255,0.65); }

  /* ── Buttons ───────────────────────────────────────── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--lp-orange);
    color: var(--lp-white);
    font-family: var(--f-display);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 13px 24px;
    transition: background 0.2s;
    cursor: pointer;
  }
  .btn-primary:hover { background: var(--lp-orange-dk); }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: 1.5px solid rgba(255,255,255,0.4);
    color: var(--lp-white);
    font-family: var(--f-display);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 13px 24px;
    transition: border-color 0.2s, background 0.2s;
    cursor: pointer;
  }
  .btn-ghost:hover { border-color: var(--lp-white); background: rgba(255,255,255,0.08); }

  .btn-white {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--lp-white);
    color: var(--lp-orange);
    font-family: var(--f-display);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 13px 28px;
    transition: opacity 0.2s;
  }
  .btn-white:hover { opacity: 0.9; }

  /* ── Section chrome ────────────────────────────────── */
  .section-header {
    max-width: var(--max-w);
    margin: 0 auto 28px;
    padding: 0 var(--gutter);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }
  .section-header h2 {
    font-family: var(--f-display);
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  /* ── Editions grid ─────────────────────────────────── */
  .editions-section { padding: 64px 0 0; }

  .editions-grid {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    gap: 28px;
  }

  .book-card {
    display: flex;
    flex-direction: column;
    cursor: pointer;
    transition: transform 0.2s;
  }
  .book-card:hover { transform: translateY(-4px); }
  .book-card--soon { opacity: 0.72; }
  .book-card--soon:hover { transform: none; }

  .book-cover-wrap {
    position: relative;
    aspect-ratio: 2/3;
    overflow: hidden;
