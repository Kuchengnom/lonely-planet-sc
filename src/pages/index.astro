---
import '../styles/global.css';

const base = import.meta.env.BASE_URL + (import.meta.env.BASE_URL.endsWith('/') ? '' : '/');

interface Edition {
  name: string;
  subtitle: string;
  tagline: string;
  status: 'available' | 'coming-soon';
  href: string;
  theme: 'stanton' | 'pyro' | 'terra' | 'nyx';
}

const EDITIONS: Edition[] = [
  {
    name: 'Stanton',
    subtitle: 'The Corporate Core',
    tagline: 'Four planets. Four corporations. One system where power is the currency.',
    status: 'available',
    href: `${base}stanton/`,
    theme: 'stanton',
  },
  {
    name: 'Pyro',
    subtitle: 'The Unstable Frontier',
    tagline: 'Six planets of volatile hostility and a near-total absence of law.',
    status: 'available',
    href: `${base}pyro/`,
    theme: 'pyro',
  },
  {
    name: 'Terra',
    subtitle: 'The Capital World',
    tagline: 'The cultural and political heart of the UEE — cosmopolitan, ambitious, complicated.',
    status: 'coming-soon',
    href: '#',
    theme: 'terra',
  },
  {
    name: 'Nyx',
    subtitle: 'The Lawless Fringe',
    tagline: "Home of Delamar and Levski. The rebel answer to Pyro's chaos.",
    status: 'coming-soon',
    href: '#',
    theme: 'nyx',
  },
];

const POIS = [
  { num: '01', name: 'The First River',      tag: 'Natural Wonder', desc: 'Open water on a permafrost world. The anomaly that has no satisfying explanation.',             planet: 'microTech · Stanton', href: `${base}stanton/microtech/`,                                        img: `${base}images/microtech/ships-on-lake.jpeg`,        alt: 'Ships parked at the edge of the first river lake basin' },
  { num: '02', name: 'Bioluminescent Caves', tag: 'Hidden Find',    desc: 'Blue-cyan ceilings that look like an inverted starfield. Not on any official map.',            planet: 'microTech · Stanton', href: `${base}stanton/microtech/`,                                        img: `${base}images/microtech/bioluminescent-cave.jpeg`,  alt: 'Bioluminescent cave ceiling covered in blue-cyan glowing organisms' },
  { num: '03', name: 'New Babbage Commons',  tag: 'Settlement',     desc: 'Corporate grandeur bordering on absurdist. The warmest welcome on the coldest planet.',        planet: 'microTech · Stanton', href: `${base}stanton/microtech/`,                                        img: `${base}images/microtech/flying-over-mountains.jpeg`, alt: 'Small ship approaching New Babbage over snowy mountain ranges' },
  { num: '04', name: 'The Canyon River',     tag: 'Natural Wonder', desc: 'Canyon walls and a colour palette that screenshots struggle to convey. Fly it slowly.',         planet: 'microTech · Stanton', href: `${base}stanton/microtech/northern-wastes/canyon-river`,           img: `${base}images/microtech/canyon-river-aerial.jpeg`,  alt: 'Aerial view of the canyon river winding through autumn forest' },
  { num: '05', name: 'Orison',               tag: 'Settlement',     desc: "A city built on platforms in the clouds of a gas giant. Nowhere else in the 'Verse like it.",  planet: 'Crusader · Stanton',  href: `${base}stanton/crusader/`,                                         img: `${base}images/microtech/panoramic-lake.jpeg`,       alt: 'Panoramic view of the Stanton system landscape' },
  { num: '06', name: 'Frozen Lakes',         tag: 'Natural Wonder', desc: 'Arches and columns of compressed blue-white ice. Walk them carefully — the footing is uneven.', planet: 'microTech · Stanton', href: `${base}stanton/microtech/`,                                        img: `${base}images/microtech/ice-arch.jpeg`,             alt: 'Ice arch formation rising from a frozen lake on MicroTech' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lonely Planet: Star Citizen</title>
    <meta name="description" content="Unofficial travel guides to the Star Citizen universe. Curated attractions, hidden gems, and essential travel tips." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Narrow:ital,wght@0,400;0,500;0,700;1,400&family=Merriweather:ital,wght@0,300;0,400;0,700;1,300;1,400&family=JetBrains+Mono&display=swap" rel="stylesheet" />
  </head>

  <body>

    <!-- Top strip -->
    <div class="top-strip">
      All Star Citizen editions are <strong>completely free</strong> — community-written, forever open access
    </div>

    <!-- Sticky header -->
    <header class="site-header">
      <div class="site-header__inner">
        <nav class="site-header__nav-left">
          <a href="#editions">Editions</a>
          <a href="#attractions">Attractions</a>
          <a href="#about">About</a>
        </nav>

        <a href={base} class="site-header__logo">
          <span class="site-header__logo-name">Lonely Planet</span>
          <span class="site-header__logo-sub">Star Citizen Edition</span>
        </a>

        <nav class="site-header__nav-right">
          <a href="https://github.com/Kuchengnom/lonely-planet-sc" target="_blank" rel="noopener">Contribute</a>
          <a href="https://robertsspaceindustries.com/" target="_blank" rel="noopener">Community</a>
        </nav>
      </div>
    </header>

    <!-- Hero -->
    <header class="hero" style={`background-image: url(${base}images/microtech/panoramic-lake.jpeg)`}>
      <div class="hero__pattern"></div>
      <div class="hero__inner">
        <p class="hero__eyebrow">New Edition Available</p>
        <h1 class="hero__title">The&nbsp;'Verse<br>awaits.<br><em>No ticket<br>needed.</em></h1>
        <p class="hero__lede">
          Unofficial travel guides to Star Citizen — written by explorers, for explorers.
          Curated attractions, hidden gems, and navigation notes for the systems you fly through.
        </p>
        <div class="hero__ctas">
          <a href={`${base}stanton/microtech/`} class="btn btn--primary">Explore microTech →</a>
          <a href="#editions" class="btn btn--ghost">Browse Editions</a>
        </div>
      </div>

      <!-- Floating edition card -->
      <div class="hero__floating-card" aria-hidden="true">
        <div class="edition-card edition-card--stanton">
          <div class="edition-card__thumb">
            <div class="edition-card__planet"></div>
            <div class="edition-card__overlay"></div>
            <span class="edition-card__lp-badge">LP</span>
            <div class="edition-card__thumb-text">
              <span class="edition-card__eyebrow">Star Citizen</span>
              <h3 class="edition-card__name">Stanton</h3>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main>

      <!-- System Editions -->
      <section class="editions" id="editions" aria-labelledby="editions-heading">
        <div class="container">
          <h2 id="editions-heading" class="section-heading">System Editions</h2>

          <div class="editions-grid">
            {EDITIONS.map((ed) => (
              <article class={`edition-card edition-card--${ed.theme} ${ed.status === 'coming-soon' ? 'edition-card--soon' : ''}`}>
                <div class="edition-card__thumb">
                  <div class="edition-card__planet" aria-hidden="true"></div>
                  <div class="edition-card__overlay"></div>
                  <span class={`edition-card__status-badge ${ed.status === 'available' ? 'edition-card__status-badge--live' : ''}`}>
                    {ed.status === 'available' ? 'Available Now' : 'Coming Soon'}
                  </span>
                  <span class="edition-card__lp-badge">LP</span>
                  <div class="edition-card__thumb-text">
                    <span class="edition-card__eyebrow">Star Citizen</span>
                    <h3 class="edition-card__name">{ed.name}</h3>
                  </div>
                </div>
                <div class="edition-card__body">
                  <p class="edition-card__subtitle">{ed.subtitle}</p>
                  <p class="edition-card__tagline">{ed.tagline}</p>
                  {ed.status === 'available' ? (
                    <a href={ed.href} class="edition-card__cta">Explore →</a>
                  ) : (
                    <span class="edition-card__cta edition-card__cta--disabled">Coming soon</span>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- Editor's Pick feature band -->
      <section class="feature-band">
        <div class="container feature-band__inner">
          <img
            class="feature-band__img"
            src={`${base}images/microtech/bioluminescent-cave.jpeg`}
            alt="Bioluminescent caves on microTech"
            loading="lazy"
          />
          <div class="feature-band__text">
            <p class="feature-band__eyebrow">Editor's Pick — Stanton IV</p>
            <h2 class="feature-band__heading">Seven reasons to land on microTech</h2>
            <p class="feature-band__body">
              Rivers that shouldn't exist, forests that refused to freeze, and caves that light
              up like an inverted starfield. The corporate ice world is the most quietly
              spectacular place in the Stanton system.
            </p>
            <div class="feature-band__stats">
              <div class="feature-stat">
                <span class="feature-stat__num">7</span>
                <span class="feature-stat__label">Attractions</span>
              </div>
              <div class="feature-stat">
                <span class="feature-stat__num">4</span>
                <span class="feature-stat__label">Hidden Finds</span>
              </div>
              <div class="feature-stat">
                <span class="feature-stat__num">1</span>
                <span class="feature-stat__label">City</span>
              </div>
            </div>
            <a href={`${base}stanton/microtech/`} class="btn btn--primary">Read the microTech Guide →</a>
          </div>
        </div>
      </section>

      <!-- Top Attractions -->
      <section class="poi-section" id="attractions" aria-labelledby="attractions-heading">
        <div class="container">
          <h2 id="attractions-heading" class="section-heading">Top Attractions</h2>
          <div class="poi-grid">
            {POIS.map((poi) => (
              <div class="poi-card">
                <button
                  class="poi-card__img-btn"
                  data-img={poi.img}
                  data-alt={poi.alt}
                  data-name={poi.name}
                  aria-label={`View full image: ${poi.alt}`}
                >
                  <img src={poi.img} alt={poi.alt} loading="lazy" />
                  <div class="poi-card__img-overlay">
                    <span class="poi-card__num">{poi.num}</span>
                    <span class="poi-card__tag-badge">{poi.tag}</span>
                  </div>
                  <span class="poi-card__zoom-hint" aria-hidden="true">⊕</span>
                </button>
                <div class="poi-card__body">
                  <a href={poi.href} class="poi-card__name">{poi.name}</a>
                  <p class="poi-card__desc">{poi.desc}</p>
                  <span class="poi-card__planet">{poi.planet}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Lightbox -->
      <dialog class="lightbox" id="lightbox" aria-modal="true" aria-label="Image viewer">
        <button class="lightbox__close" id="lightbox-close" aria-label="Close">✕</button>
        <figure class="lightbox__figure">
          <img class="lightbox__img" id="lightbox-img" src="" alt="" />
          <figcaption class="lightbox__caption" id="lightbox-caption"></figcaption>
        </figure>
      </dialog>

      <script>
        const dialog = document.getElementById('lightbox') as HTMLDialogElement;
        const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
        const lbCaption = document.getElementById('lightbox-caption') as HTMLElement;
        const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement;

        document.querySelectorAll<HTMLButtonElement>('.poi-card__img-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            lbImg.src = btn.dataset.img ?? '';
            lbImg.alt = btn.dataset.alt ?? '';
            lbCaption.textContent = btn.dataset.name ?? '';
            dialog.showModal();
          });
        });

        closeBtn.addEventListener('click', () => dialog.close());
        dialog.addEventListener('click', (e) => { if (e.target === dialog) dialog.close(); });
      </script>

      <!-- Community manifesto -->
      <section class="manifesto" id="about">
        <div class="manifesto__inner">
          <h2 class="manifesto__heading">The 'Verse belongs to everyone.<br />So do these guides.</h2>
          <p class="manifesto__body">
            Lonely Planet: Star Citizen Edition is a fan-made, community-driven project.
            No subscriptions, no paywalls — every guide is written by explorers and released freely.
            Found a hidden gem? Help us map the 'Verse.
          </p>
          <a href="https://github.com/Kuchengnom/lonely-planet-sc" class="btn btn--outline-white" target="_blank" rel="noopener">
            Contribute on GitHub →
          </a>
        </div>
      </section>

    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="container site-footer__grid">
        <div class="site-footer__brand">
          <p class="site-footer__logo">Lonely Planet</p>
          <p class="site-footer__blurb">
            Unofficial fan guide to the Star Citizen universe. Written by explorers, for explorers.
            Star Citizen and related marks belong to Cloud Imperium Rights LLC.
          </p>
        </div>
        <div>
          <p class="footer-title">Editions</p>
          <ul class="footer-links">
            <li><a href={`${base}stanton/`}>Stanton</a></li>
            <li><a href={`${base}stanton/microtech/`}>microTech</a></li>
            <li><a href={`${base}stanton/crusader/`}>Crusader</a></li>
            <li><a href={`${base}stanton/hurston/`}>Hurston</a></li>
            <li><a href={`${base}stanton/arccorp/`}>ArcCorp</a></li>
            <li><a href={`${base}pyro/`}>Pyro</a></li>
          </ul>
        </div>
        <div>
          <p class="footer-title">Community</p>
          <ul class="footer-links">
            <li><a href="https://robertsspaceindustries.com/" target="_blank" rel="noopener">Star Citizen</a></li>
            <li><a href="https://starcitizen.tools/" target="_blank" rel="noopener">Star Citizen Wiki</a></li>
            <li><a href="https://github.com/Kuchengnom/lonely-planet-sc" target="_blank" rel="noopener">GitHub Repo</a></li>
          </ul>
        </div>
        <div>
          <p class="footer-title">Project</p>
          <ul class="footer-links">
            <li><a href="#about">About</a></li>
            <li><a href="https://github.com/Kuchengnom/lonely-planet-sc" target="_blank" rel="noopener">How to Contribute</a></li>
          </ul>
        </div>
      </div>
      <div class="container site-footer__bottom">
        <span>Fan-made reference guide. Not affiliated with Cloud Imperium Games.</span>
        <span>Lonely Planet: Star Citizen Edition</span>
      </div>
    </footer>

  </body>
</html>

<style>
  /* ── Base ──────────────────────────────────────────── */
  body {
    background: var(--color-neutral-50);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ── Top strip ─────────────────────────────────────── */
  .top-strip {
    background: var(--color-neutral-900);
    color: var(--color-neutral-400);
    font-family: var(--font-display);
    font-size: 0.6875rem;
    letter-spacing: var(--letter-spacing-widest);
    text-transform: uppercase;
    text-align: center;
    padding: var(--space-2) var(--space-6);
  }
  .top-strip strong {
    color: #f5c518;
    font-weight: var(--font-weight-bold);
  }

  /* ── Sticky header ─────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: var(--color-white);
    border-bottom: 2px solid var(--color-neutral-900);
  }

  .site-header__inner {
    max-width: var(--container-xl);
    margin: 0 auto;
    padding: 0 var(--space-6);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 60px;
  }

  .site-header__nav-left,
  .site-header__nav-right {
    display: flex;
    gap: var(--space-6);
    font-family: var(--font-display);
    font-size: 0.6875rem;
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-widest);
    text-transform: uppercase;
    color: var(--color-neutral-700);
  }
  .site-header__nav-right { justify-content: flex-end; }
  .site-header__nav-left  a:hover,
  .site-header__nav-right a:hover { color: var(--color-primary-600); }

  .site-header__logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
  }
  .site-header__logo-name {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: var(--font-weight-extrabold);
    letter-spacing: var(--letter-spacing-tight);
    text-transform: uppercase;
    color: var(--color-neutral-900);
    line-height: 1;
  }
  .site-header__logo-sub {
    font-family: var(--font-display);
    font-size: 0.5rem;
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-neutral-500);
    margin-top: 2px;
  }

  /* ── Hero ──────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: stretch;
    background-color: var(--color-primary-900);
    background-size: cover;
    background-position: center 35%;
    color: var(--color-white);
    overflow: hidden;
  }

  /* Dark overlay layers */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, rgba(9,20,45,0.88) 0%, rgba(9,20,45,0.35) 65%),
      linear-gradient(to bottom, rgba(9,20,45,0.3) 0%, transparent 40%);
  }

  .hero__pattern {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.04) 2px,
      rgba(0,0,0,0.04) 4px
    );
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    max-width: var(--container-xl);
    width: 100%;
    margin: 0 auto;
    padding: var(--space-20) var(--space-6) var(--space-16);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    max-width: 580px;
  }

  .hero__eyebrow {
    font-family: var(--font-display);
    font-size: 0.625rem;
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-primary-300);
    margin-bottom: var(--space-3);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .hero__eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-primary-400);
    flex-shrink: 0;
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6.5vw, 5rem);
    font-weight: var(--font-weight-extrabold);
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    text-transform: uppercase;
    color: var(--color-white);
    margin: 0 0 var(--space-5);
  }
  .hero__title em {
    font-style: normal;
    color: #f5c518;
  }

  .hero__lede {
    font-family: var(--font-body);
    font-size: clamp(0.875rem, 1.6vw, 1rem);
    line-height: var(--line-height-relaxed);
    color: rgba(255,255,255,0.72);
    max-width: 440px;
    margin: 0 0 var(--space-8);
  }

  .hero__ctas {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* Floating edition card in hero */
  .hero__floating-card {
    position: absolute;
    right: clamp(24px, 6vw, 80px);
    bottom: 0;
    width: clamp(140px, 16vw, 220px);
    filter: drop-shadow(var(--shadow-2xl));
    animation: float-card 5s ease-in-out infinite;
    z-index: 3;
  }
  .hero__floating-card .edition-card {
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: none;
  }
  .hero__floating-card .edition-card__thumb {
    height: clamp(210px, 24vw, 330px);
  }

  @keyframes float-card {
    0%, 100% { transform: rotate(2deg) translateY(0); }
    50%       { transform: rotate(2deg) translateY(-8px); }
  }

  /* ── Shared buttons ────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: 0.6875rem;
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-widest);
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.8125rem var(--space-6);
    transition: background var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out);
    cursor: pointer;
    border: none;
  }
  .btn--primary {
    background: var(--color-primary-600);
    color: var(--color-white);
  }
  .btn--primary:hover { background: var(--color-primary-700); }

  .btn--ghost {
    background: transparent;
    border: 1.5px solid rgba(255,255,255,0.4);
    color: var(--color-white);
  }
  .btn--ghost:hover { border-color: var(--color-white); background: rgba(255,255,255,0.08); }

  .btn--outline-white {
    background: transparent;
    border: 1.5px solid rgba(255,255,255,0.6);
    color: var(--color-white);
  }
  .btn--outline-white:hover { background: rgba(255,255,255,0.1); border-color: var(--color-white); }

  /* ── Section heading (shared with rest of site) ────── */
  .section-heading {
    font-family: var(--font-display);
    font-size: 0.625rem;
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-widest);
    text-transform: uppercase;
    color: var(--color-neutral-500);
    margin: 0 0 var(--space-5);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-neutral-200);
  }

  /* ── Edition cards (unchanged from original) ───────── */
  .editions { padding: var(--space-16) 0; }

  .editions-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
  }

  .edition-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
    background: var(--color-white);
  }
  .edition-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-xl); }
  .edition-card--soon { opacity: 0.85; }
  .edition-card--soon:hover { transform: none; box-shadow: var(--shadow-sm); }

  .edition-card__thumb {
    position: relative;
    height: 220px;
    overflow: hidden;
  }
  .edition-card--stanton .edition-card__thumb { background: linear-gradient(160deg, #1e3a5c 0%, #0d1f35 55%, #040c18 100%); }
  .edition-card--pyro    .edition-card__thumb { background: linear-gradient(160deg, #3a1a0a 0%, #1e0d04 55%, #0a0400 100%); }
  .edition-card--terra   .edition-card__thumb { background: linear-gradient(160deg, #0a2a1a 0%, #051510 55%, #020a06 100%); }
